# ─── Supabase (Postgres only — no auth) ─────────────────────────────
# Get from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — used ONLY on the server (server actions, admin
# routes) to bypass RLS. Never expose to the browser. We're not turning
# on RLS for this small app anyway, but keep it server-side as a habit.
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Admin password (single shared) ─────────────────────────────────
# Used to log into /admin. Set to a strong random string.
ADMIN_PASSWORD=""

# ─── Session signing secret ─────────────────────────────────────────
# iron-session uses this to sign the admin-auth cookie. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=""

# ─── Resend (email blast) ───────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=""
# "From" address on logistics emails — must be on a Resend-verified
# domain. For testing: "onboarding@resend.dev" (only delivers to the
# Resend account email).
RESEND_FROM_EMAIL="dossier@operation-mission-complete.app"

# ─── App URL (used by QR generator) ─────────────────────────────────
# In production, set to your deployed Vercel URL (https://...).
# Drives the URLs the QR codes encode.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
